{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mafyuh/renovate"
  ],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Linux kernel version",
      "managerFilePatterns": ["/\\.nix$/"],
      "matchStrings": [
        "linuxPackages_(?<currentValue>\\d+_\\d+)"
      ],
      "depNameTemplate": "linux",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose"
    }
  ]
}
